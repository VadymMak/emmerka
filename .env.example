# ── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL (pgvector-enabled). Get it at https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ── Store identity ───────────────────────────────────────────────────────────
# Slug of your store row in DB — must match the seed value
STORE_SLUG=my-restaurant

# ── Vercel Blob ──────────────────────────────────────────────────────────────
# For gallery image uploads. Create a Blob store in Vercel dashboard.
BLOB_READ_WRITE_TOKEN=

# ── OpenAI (AI admin assistant) ──────────────────────────────────────────────
# Required for the AI chat in admin panel (/admin/ai)
OPENAI_API_KEY=

# ── Admin security ───────────────────────────────────────────────────────────
# HMAC secret for admin cookie signing — generate a strong random string
ADMIN_SECRET=change-me-in-production

# ── Public base URL ──────────────────────────────────────────────────────────
# Used for SEO canonical / og:url — do NOT set to localhost in production
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
